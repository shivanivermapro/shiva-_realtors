<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Shiva Realty | Find Your Perfect Home</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="styles.css" />
</head>
<body>

  <div class="page-wrapper">

    <!-- HEADER / NAV -->
    <header class="site-header">
      <div class="container header-inner">
        <a href="#" class="logo">
          <span class="logo-mark">SR</span>
          <span class="logo-text">Shiva Realty</span>
        </a>

        <nav class="main-nav">
          <ul>
            <li><a href="#hero">Home</a></li>
            <li><a href="#properties">Properties</a></li>
            <li><a href="#why-us">Why Us</a></li>
            <li><a href="#contact">Enquiry</a></li>
          </ul>
        </nav>

        <button class="btn-primary btn-header">
          Call Now
        </button>

        <!-- Mobile menu toggle -->
        <button class="nav-toggle" aria-label="Toggle navigation">
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <!-- HERO SECTION -->
    <section id="hero" class="hero-section">
      <div class="container hero-grid">
        <div class="hero-text">
          <span class="eyebrow">Real Estate Agency</span>
          <h1>Find your next home with confidence.</h1>
          <p>
            We help you buy, sell, and rent properties in the most sought-after
            locations. Transparent processes, expert guidance, and carefully
            curated listings.
          </p>

          <form class="property-search">
            <div class="field-group">
  <label for="location">Location</label>
  <select id="location">
    <option value="">Any location</option>

    <optgroup label="Major Cities">
      <option>Mumbai</option>
      <option>Delhi</option>
      <option>Bengaluru</option>
      <option>Hyderabad</option>
      <option>Chennai</option>
      <option>Kolkata</option>
      <option>Pune</option>
      <option>Ahmedabad</option>
      <option>Jaipur</option>
      <option>Chandigarh</option>
    </optgroup>

    <optgroup label="States">
      <option>Andhra Pradesh</option>
      <option>Arunachal Pradesh</option>
      <option>Assam</option>
      <option>Bihar</option>
      <option>Chhattisgarh</option>
      <option>Goa</option>
      <option>Gujarat</option>
      <option>Haryana</option>
      <option>Himachal Pradesh</option>
      <option>Jharkhand</option>
      <option>Karnataka</option>
      <option>Kerala</option>
      <option>Madhya Pradesh</option>
      <option>Maharashtra</option>
      <option>Manipur</option>
      <option>Meghalaya</option>
      <option>Mizoram</option>
      <option>Nagaland</option>
      <option>Odisha</option>
      <option>Punjab</option>
      <option>Rajasthan</option>
      <option>Sikkim</option>
      <option>Tamil Nadu</option>
      <option>Telangana</option>
      <option>Tripura</option>
      <option>Uttar Pradesh</option>
      <option>Uttarakhand</option>
      <option>West Bengal</option>
    </optgroup>

    <optgroup label="Union Territories">
      <option>Andaman and Nicobar Islands</option>
      <option>Chandigarh</option>
      <option>Dadra and Nagar Haveli and Daman and Diu</option>
      <option>Delhi</option>
      <option>Jammu and Kashmir</option>
      <option>Ladakh</option>
      <option>Lakshadweep</option>
      <option>Puducherry</option>
    </optgroup>
  </select>
</div>


            <div class="field-group">
              <label for="type">Property Type</label>
              <select id="type">
                <option value="">Any</option>
                <option>Apartment</option>
                <option>Villa</option>
                <option>Plot</option>
                <option>Commercial</option>
              </select>
            </div>

            <div class="field-group">
              <label for="budget">Max Budget</label>
              <select id="budget">
                <option value="">No limit</option>
                <option>₹50L</option>
                <option>₹1Cr</option>
                <option>₹2Cr</option>
                <option>₹5Cr+</option>
              </select>
            </div>

            <button type="submit" class="btn-primary search-btn">
              Search Properties
            </button>
          </form>

          <div class="hero-stats">
            <div>
              <strong>250+</strong>
              <span>Properties Listed</span>
            </div>
            <div>
              <strong>120+</strong>
              <span>Happy Clients</span>
            </div>
            <div>
              <strong>10+</strong>
              <span>Years Experience</span>
            </div>
          </div>
        </div>

        <div class="hero-media">
          <div class="hero-card hero-card-main">
            <span class="badge badge-sale">For Sale</span>
            <h3>3 BHK Luxury Apartment</h3>
            <p class="hero-location">Kharadi, Pune</p>
            <p class="hero-price">₹1.25 Cr</p>
            <div class="hero-meta">
              <span>3 Beds</span>
              <span>3 Baths</span>
              <span>1,650 sq.ft</span>
            </div>
          </div>

          <div class="hero-card hero-card-small">
            <span class="badge badge-rent">For Rent</span>
            <h4>2 BHK Furnished</h4>
            <p class="hero-location">Whitefield, Bangalore</p>
            <p class="hero-price">₹45,000 / mo</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROPERTIES SECTION -->
    <section id="properties" class="properties-section">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="eyebrow">Featured Listings</span>
            <h2>Properties handpicked for you</h2>
          </div>
          <a href="#" class="link-more">View all listings →</a>
        </div>

        <div class="properties-grid">

          <!-- Property Card 1 -->
          <article class="property-card">
            <div class="property-image property-image-1">
              <span class="badge badge-sale">For Sale</span>
            </div>
            <div class="property-body">
              <h3>Luxury 3 BHK Apartment</h3>
              <p class="property-location">Kharadi, Pune</p>
              <p class="property-price">₹1.25 Cr</p>
              <div class="property-meta">
                <span>3 Beds</span>
                <span>3 Baths</span>
                <span>1,650 sq.ft</span>
              </div>
              <button class="btn-outline">Enquire Now</button>
            </div>
          </article>

          <!-- Property Card 2 -->
          <article class="property-card">
            <div class="property-image property-image-2">
              <span class="badge badge-rent">For Rent</span>
            </div>
            <div class="property-body">
              <h3>Furnished 2 BHK Apartment</h3>
              <p class="property-location">Whitefield, Bangalore</p>
              <p class="property-price">₹45,000 / mo</p>
              <div class="property-meta">
                <span>2 Beds</span>
                <span>2 Baths</span>
                <span>1,100 sq.ft</span>
              </div>
              <button class="btn-outline">Enquire Now</button>
            </div>
          </article>

          <!-- Property Card 3 -->
          <article class="property-card">
            <div class="property-image property-image-3">
              <span class="badge badge-sale">For Sale</span>
            </div>
            <div class="property-body">
              <h3>Independent 4 BHK Villa</h3>
              <p class="property-location">Gachibowli, Hyderabad</p>
              <p class="property-price">₹3.2 Cr</p>
              <div class="property-meta">
                <span>4 Beds</span>
                <span>5 Baths</span>
                <span>3,200 sq.ft</span>
              </div>
              <button class="btn-outline">Enquire Now</button>
            </div>
          </article>

          <!-- Property Card 4 -->
          <article class="property-card">
            <div class="property-image property-image-4">
              <span class="badge badge-sale">For Sale</span>
            </div>
            <div class="property-body">
              <h3>Premium Residential Plot</h3>
              <p class="property-location">New Town, Kolkata</p>
              <p class="property-price">₹90 L</p>
              <div class="property-meta">
                <span>2,400 sq.ft</span>
                <span>East Facing</span>
                <span>Gated Community</span>
              </div>
              <button class="btn-outline">Enquire Now</button>
            </div>
          </article>

          <!-- Property Card 5 -->
          <article class="property-card">
            <div class="property-image property-image-5">
              <span class="badge badge-rent">For Rent</span>
            </div>
            <div class="property-body">
              <h3>Co-working Office Space</h3>
              <p class="property-location">Baner, Pune</p>
              <p class="property-price">₹1,200 / seat</p>
              <div class="property-meta">
                <span>50 Seats</span>
                <span>24×7 Access</span>
                <span>Parking</span>
              </div>
              <button class="btn-outline">Enquire Now</button>
            </div>
          </article>

          <!-- Property Card 6 -->
          <article class="property-card">
            <div class="property-image property-image-6">
              <span class="badge badge-sale">For Sale</span>
            </div>
            <div class="property-body">
              <h3>Studio Apartment</h3>
              <p class="property-location">Andheri West, Mumbai</p>
              <p class="property-price">₹80 L</p>
              <div class="property-meta">
                <span>1 Bed</span>
                <span>1 Bath</span>
                <span>550 sq.ft</span>
              </div>
              <button class="btn-outline">Enquire Now</button>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- WHY US SECTION -->
    <section id="why-us" class="why-section">
      <div class="container why-grid">
        <div>
          <span class="eyebrow">Why choose us</span>
          <h2>We simplify your property journey.</h2>
          <p>
            From site visits to paperwork, we handle every step with clarity and
            care. Our team is focused on finding properties that match your
            budget, location, and lifestyle.
          </p>

          <ul class="why-list">
            <li>
              <h3>Curated Listings</h3>
              <p>Every property is verified and inspected before listing.</p>
            </li>
            <li>
              <h3>End-to-End Support</h3>
              <p>Loans, legal support, paperwork – we assist with it all.</p>
            </li>
            <li>
              <h3>Local Expertise</h3>
              <p>In-depth knowledge of micro-markets and upcoming projects.</p>
            </li>
          </ul>
        </div>

        <div class="why-cards">
          <div class="stat-card">
            <strong>92%</strong>
            <span>Deals closed within 60 days</span>
          </div>
          <div class="stat-card">
            <strong>4.9/5</strong>
            <span>Average client rating</span>
          </div>
          <div class="stat-card">
            <strong>15+</strong>
            <span>Partner builders</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT / ENQUIRY SECTION -->
    <section id="contact" class="contact-section">
      <div class="container contact-grid">
        <div class="contact-text">
          <span class="eyebrow">Enquiry</span>
          <h2>Tell us what you're looking for.</h2>
          <p>
            Share your requirements and we’ll get back with options that fit.
            No spam, no pushy calls – just honest guidance.
          </p>

          <div class="contact-details">
            <p><strong>Phone:</strong> +91-98765-43210</p>
            <p><strong>Email:</strong> hello@shivarealty.com</p>
            <p><strong>Office:</strong> MG Road, Bengaluru, India</p>
          </div>
        </div>

        <form class="contact-form">
          <div class="form-row">
            <div class="field-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" placeholder="Your name" required />
            </div>
            <div class="field-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" placeholder="Your phone" required />
            </div>
          </div>

          <div class="form-row">
            <div class="field-group">
              <label for="email">Email</label>
              <input type="email" id="email" placeholder="you@example.com" required />
            </div>
            <div class="field-group">
              <label for="purpose">Looking to</label>
              <select id="purpose" required>
                <option value="">Select</option>
                <option>Buy</option>
                <option>Rent</option>
                <option>Sell</option>
                <option>Invest</option>
              </select>
            </div>
          </div>

          <div class="field-group">
            <label for="preferred-location">Preferred Location</label>
            <input type="text" id="preferred-location" placeholder="City / Area" />
          </div>

          <div class="field-group">
            <label for="budget-range">Approx. Budget Range</label>
            <select id="budget-range">
              <option value="">Select</option>
              <option>Below ₹50L</option>
              <option>₹50L – ₹1Cr</option>
              <option>₹1Cr – ₹2Cr</option>
              <option>₹2Cr – ₹5Cr</option>
              <option>₹5Cr+</option>
            </select>
          </div>

          <div class="field-group">
            <label for="message">Additional Details</label>
            <textarea id="message" rows="4" placeholder="Share any preferences or property IDs"></textarea>
          </div>

          <button type="submit" class="btn-primary btn-full">
            Submit Enquiry
          </button>
        </form>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>© <span id="year"></span> Shiva Realty. All rights reserved.</p>
        <p class="footer-credit">Designed &amp; coded by You.</p>
      </div>
    </footer>

  </div>

  <!-- Minimal JS for mobile menu + year -->
  <script>
    const navToggle = document.querySelector('.nav-toggle');
    const header = document.querySelector('.site-header');
    navToggle.addEventListener('click', () => {
      header.classList.toggle('nav-open');
    });

    const yearSpan = document.getElementById('year');
    yearSpan.textContent = new Date().getFullYear();
  </script>

</body>
</html>
